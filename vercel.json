{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/static/(.*)",
            "destination": "/client/static/$1"
        },
        {
            "source": "/models/(.*)",
            "destination": "/client/models/$1"
        },
        {
            "source": "/images/(.*)",
            "destination": "/client/images/$1"
        },
        {
            "source": "/(favicon.ico|manifest.json|robots.txt)",
            "destination": "/client/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/client/index.html"
        }
    ]
}